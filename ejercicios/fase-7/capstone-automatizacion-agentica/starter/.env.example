# Copia este archivo a .env y rellena los valores. NUNCA commitees .env con secretos reales.
# (Añade .env a tu .gitignore; el secret-scanning del CI — punto 3 del DoD — debe atrapar fugas.)

# Clave de la API de Anthropic para la extracción (el "cerebro").
ANTHROPIC_API_KEY=

# Secreto compartido para verificar la firma HMAC del webhook de entrada (OWASP web).
WEBHOOK_HMAC_SECRET=

# Endpoint del servidor Temporal (ejecución durable).
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=capstone-agentic

# Techo de costo del run en USD (circuit-breaker; punto 5/6 del DoD).
TECHO_COSTO_USD=2.0

# Endpoint del colector OTel para las trazas (observabilidad; punto 4 del DoD).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
