#!/usr/bin/env bash
#
# commit-msg — valida que el mensaje de commit siga Conventional Commits.
#
# Git invoca este hook con UN argumento: la ruta del archivo temporal que
# contiene el mensaje propuesto ($1). Si el script sale con código distinto
# de 0, Git ABORTA el commit.
#
# Esta es la versión COMPLETA del hook que construiste en la sub-unidad 0.6.
# Cópiala a tu proyecto:
#
#   mkdir -p .githooks && cp plantillas/commit-msg .githooks/
#   chmod +x .githooks/commit-msg
#   git config core.hooksPath .githooks
#
set -euo pipefail

msg_file="$1"

# Cabecera = primera línea no vacía que no empiece con '#'.
# (awk lee el archivo directo: sin pipes frágiles ni problemas de SIGPIPE.)
header="$(awk 'NF==0 {next} /^#/ {next} {print; exit}' "$msg_file")"

# Deja pasar los mensajes autogenerados por Git (merge/revert): no son
# Conventional Commits y no deben validarse como tales.
case "$header" in
  "Merge "* | "Revert "*) exit 0 ;;
esac

# Patrón Conventional Commits: <type>[(scope)][!]: <descripción>
#   tipos válidos: feat fix docs style refactor perf test build ci chore revert
pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?(!)?: .+'

if printf '%s' "$header" | grep -Eq "$pattern"; then
  exit 0
fi

cat >&2 <<'EOF'
✗ El mensaje de commit no sigue Conventional Commits.

  Formato:  <type>[(scope)][!]: <descripción>
  Tipos:    feat fix docs style refactor perf test build ci chore revert

  Ejemplos válidos:
    feat: agrega comando resumen
    fix(cli): no sobrescribir si el destino ya existe
    docs: agrega SPEC inicial
    feat!: cambia el formato de salida (breaking)

Corrige el mensaje y vuelve a commitear.
EOF
exit 1
