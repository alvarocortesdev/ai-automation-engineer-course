# Plantilla de secretos. Copia a .env y rellena con valores reales.
# El .env REAL va en .gitignore — NUNCA lo commitees. gitleaks lo verifica en CI.

# Genera uno con:  openssl rand -hex 32   (NUNCA reutilices este de ejemplo)
SECRET_KEY=cambia-esto-por-uno-generado-con-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Base de datos (en docker-compose suele ser el nombre del servicio, p.ej. "db")
DATABASE_URL=postgresql+psycopg://api:api@localhost:5432/miapi

# Rate limiting (ejemplos; ajústalos en tu spec)
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_IMPORT=10/minute

# Nivel de log (INFO en prod, DEBUG en dev)
LOG_LEVEL=INFO
