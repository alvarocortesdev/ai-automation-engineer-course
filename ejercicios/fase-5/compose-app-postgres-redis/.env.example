# Copia este archivo a `.env` y rellena los valores reales.
# `.env` va al .gitignore: NUNCA se commitea. Este `.env.example` sí (documenta
# qué variables necesita el stack, sin exponer secretos reales).

# Contraseña de Postgres. Compose la inyecta como ${POSTGRES_PASSWORD}.
# En tu .env real pon una contraseña fuerte; aquí solo documentamos la variable.
POSTGRES_PASSWORD=cambia-esto-en-tu-.env
