# 12-factor: TODA la config va en el entorno, nunca en el código ni commiteada con valores.
# Este archivo lista las CLAVES (sin valores reales). Cópialo a .env (gitignored) para dev,
# y en CI/prod inyecta los secretos desde el secrets-manager (GitHub Actions secrets / runtime).
#
# TODO: completa con las claves REALES que tu app necesita. Ejemplos de partida:

# --- App ---
APP_ENV=                 # dev | staging | prod
PORT=8000

# --- Base de datos (SECRETO: nunca commitear el valor real) ---
DATABASE_URL=            # postgres://user:pass@host:5432/db

# --- Auth (SECRETO) ---
JWT_SECRET=              # genera uno fuerte; distinto por ambiente

# --- Seguridad web ---
CORS_ALLOWED_ORIGINS=    # lista acotada, NUNCA "*"

# --- Observabilidad (5.10) ---
OTEL_EXPORTER_OTLP_ENDPOINT=   # vacío en dev (ConsoleSpanExporter); URL del colector en prod
OTEL_SERVICE_NAME=             # identifica TU servicio en las trazas

# Marca con un comentario cuáles de estas son SECRETO. Los secretos NO viven aquí con valor:
# viven en el entorno de ejecución.
